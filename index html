<script>
marked.setOptions({gfm:true,breaks:true});

async function loadContent(){
  let text=null;
  for(const p of['metasystem_srb.md','./metasystem_srb.md']){
    try{const r=await fetch(p);if(r.ok){text=await r.text();break}}catch(e){}
  }
  if(!text){
    document.getElementById('content').innerHTML=`<div class="cterr"><h2>Greška pri učitavanju</h2><p>Fajl <code>metasystem_srb.md</code> nije pronađen.</p><p style="margin-top:.75rem;font-size:.85rem;color:var(--muted)">Proverite da se fajl nalazi u istom folderu kao index.html na GitHub Pages.</p></div>`;
    return;
  }
  render(text);
}

function sl(t){
  return t.toLowerCase()
    .replace(/[šŠ]/g,'s').replace(/[čČćĆ]/g,'c').replace(/[žŽ]/g,'z').replace(/[đĐ]/g,'d')
    .replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'').substring(0,45);
}

function render(md){
  const el=document.getElementById('content');
  el.innerHTML=marked.parse(md);
  el.querySelectorAll('h1,h2,h3,h4').forEach((h,i)=>{h.id='h'+i+'-'+sl(h.textContent)});
  buildTOC();
  rtime(md);
  spy();
}

function buildTOC(){
  const hs=document.querySelectorAll('#content h2,#content h3');
  const toc=document.getElementById('toc');
  if(!hs.length){toc.innerHTML='<div class="tocinfo">Nema naslova.</div>';return}
  let html='<ul class="toclist">';
  hs.forEach(h=>{
    const sub=h.tagName==='H3';
    html+=`<li class="tocitem${sub?' tocsub':''}"><a class="toclink" href="#${h.id}" data-id="${h.id}"><span class="tocdot"></span><span class="toclbl">${h.textContent.trim()}</span></a></li>`;
  });
  html+='</ul>';
  toc.innerHTML=html;
  toc.querySelectorAll('.toclink').forEach(a=>{
    a.addEventListener('click',e=>{
      e.preventDefault();
      const t=document.getElementById(a.dataset.id);
      if(t)window.scrollTo({top:t.getBoundingClientRect().top+scrollY-80,behavior:'smooth'});
      if(window.innerWidth<1024)closeSB();
    });
  });
}

function rtime(md){
  document.getElementById('rtime').textContent='~'+Math.ceil(md.trim().split(/\s+/).length/200)+' min čitanja';
}

function spy(){
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        const id=e.target.id;
        document.querySelectorAll('.toclink').forEach(a=>a.classList.toggle('active',a.dataset.id===id));
        const al=document.querySelector(`.toclink[data-id="${id}"]`);
        if(al)al.scrollIntoView({block:'nearest',behavior:'smooth'});
      }
    });
  },{rootMargin:'-70px 0px -70% 0px',threshold:0});
  document.querySelectorAll('#content h2,#content h3').forEach(h=>obs.observe(h));
}

window.addEventListener('scroll',()=>{
  const dh=document.documentElement.scrollHeight-innerHeight;
  document.getElementById('pb').style.width=(dh>0?scrollY/dh*100:0)+'%';
  document.getElementById('btt').classList.toggle('on',scrollY>400);
},{passive:true});
document.getElementById('btt').addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));

function openSB(){document.getElementById('sb').classList.add('open');document.getElementById('ov').classList.add('on');document.body.style.overflow='hidden'}
function closeSB(){document.getElementById('sb').classList.remove('open');document.getElementById('ov').classList.remove('on');document.body.style.overflow=''}
document.getElementById('hbgbtn').addEventListener('click',openSB);
document.getElementById('ov').addEventListener('click',closeSB);

let matches=[],idx=0;
function openSearch(){document.getElementById('srchbar').classList.remove('hidden');document.getElementById('srchq').focus()}
function closeSearch(){document.getElementById('srchbar').classList.add('hidden');clearHL();document.getElementById('srchq').value='';document.getElementById('srchcnt').textContent='';matches=[]}

['srchbtn','msrch'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('click',openSearch)});
document.getElementById('sclose').addEventListener('click',closeSearch);
['pdfbtn','mpdf'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('click',()=>window.print())});

document.getElementById('srchq').addEventListener('input',function(){
  clearHL();matches=[];idx=0;
  document.getElementById('srchcnt').textContent='';
  if(this.value.trim().length>=2)doSearch(this.value.trim());
});
document.getElementById('sprev').addEventListener('click',()=>nav(-1));
document.getElementById('snext').addEventListener('click',()=>nav(1));
document.getElementById('srchq').addEventListener('keydown',e=>{
  if(e.key==='Enter')nav(e.shiftKey?-1:1);
  if(e.key==='Escape')closeSearch();
});

function doSearch(q){
  const re=new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'gi');
  const walker=document.createTreeWalker(document.getElementById('content'),NodeFilter.SHOW_TEXT);
  const nodes=[];let n;
  while((n=walker.nextNode())){
    if(re.test(n.textContent)&&!['SCRIPT','STYLE','MARK'].includes(n.parentNode.tagName))nodes.push(n);
  }
  nodes.forEach(n=>{
    const s=document.createElement('span');
    s.innerHTML=n.textContent.replace(re,m=>`<mark class="sh">${m}</mark>`);
    n.parentNode.replaceChild(s,n);
  });
  matches=[...document.querySelectorAll('mark.sh')];
  document.getElementById('srchcnt').textContent=matches.length?`${matches.length} rezultata`:'Nema rezultata';
  if(matches.length)nav(0);
}

function nav(d){
  if(!matches.length)return;
  matches[idx]?.classList.remove('cur');
  idx=(idx+d+matches.length)%matches.length;
  matches[idx].classList.add('cur');
  matches[idx].scrollIntoView({behavior:'smooth',block:'center'});
  document.getElementById('srchcnt').textContent=`${idx+1} / ${matches.length}`;
}

function clearHL(){
  document.querySelectorAll('mark.sh').forEach(m=>{m.parentNode.replaceChild(document.createTextNode(m.textContent),m);m.parentNode.normalize()});
}

loadContent();
</script>
</body>
