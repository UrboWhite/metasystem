<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d0d0d;--surface:#161616;--surface2:#1f1f1f;--border:#2e2e2e;
  --gold:#c8a96e;--blue:#7eb8c9;--text:#eae6de;--text2:#a8a094;--muted:#5a5550;
  --sidebar:280px;--hdr:60px;--actions:46px;
}
html{scroll-behavior:smooth;font-size:18px}
body{background:var(--bg);color:var(--text);font-family:'Open Sans',sans-serif;line-height:1.8;overflow-x:hidden}
a{color:var(--gold);text-decoration:none}
a:hover{text-decoration:underline;color:#debb7e}
::selection{background:rgba(200,169,110,.25);color:var(--text)}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* PROGRESS */
#pb{position:fixed;top:0;left:0;height:3px;width:0;background:linear-gradient(90deg,var(--gold),var(--blue));z-index:9999;transition:width .1s linear}

/* MOBILE HEADER */
#mhdr{display:none;position:fixed;top:0;left:0;right:0;height:var(--hdr);background:var(--surface);border-bottom:1px solid var(--border);align-items:center;padding:0 1rem;gap:.6rem;z-index:500}
.mtitle{font-family:'Playfair Display',serif;font-size:.88rem;color:var(--gold);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mibtn{background:none;border:none;color:var(--text2);cursor:pointer;padding:8px;display:flex;align-items:center;justify-content:center;border-radius:6px;transition:background .2s;min-width:44px;min-height:44px;flex-shrink:0}
.mibtn:hover{background:var(--surface2);color:var(--text)}
.hbg{display:flex;flex-direction:column;gap:5px}
.hbg span{display:block;width:20px;height:2px;background:var(--text);border-radius:1px}

/* MOBILE ACTIONS ROW */
#mact{display:none;position:fixed;top:var(--hdr);left:0;right:0;background:var(--surface);border-bottom:1px solid var(--border);padding:.5rem 1rem;gap:.4rem;flex-wrap:wrap;z-index:499;align-items:center}
.mbadge{display:inline-flex;align-items:center;gap:.3rem;padding:.28rem .6rem;border-radius:4px;font-size:.68rem;text-decoration:none;border:1px solid transparent;transition:all .2s;white-space:nowrap;cursor:pointer;background:none;font-family:'Open Sans',sans-serif}
.mbadge:hover{text-decoration:none}
.mb-g{background:rgba(166,206,57,.1);border-color:rgba(166,206,57,.3);color:#a6ce39}
.mb-g:hover{background:rgba(166,206,57,.2);border-color:#a6ce39}
.mb-a{background:rgba(200,169,110,.1);border-color:rgba(200,169,110,.3);color:var(--gold)}
.mb-a:hover{background:rgba(200,169,110,.2);border-color:var(--gold)}
.mb-r{background:rgba(255,94,91,.1);border-color:rgba(255,94,91,.3);color:#ff5e5b}
.mb-r:hover{background:rgba(255,94,91,.2);border-color:#ff5e5b}
.mb-n{background:var(--surface2);border-color:var(--border);color:var(--text2)}
.mb-n:hover{background:var(--border);color:var(--text)}

/* OVERLAY */
#ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:398;opacity:0;transition:opacity .3s}
#ov.on{opacity:1}

/* SIDEBAR */
#sb{position:fixed;top:0;left:0;bottom:0;width:var(--sidebar);background:var(--surface);border-right:1px solid var(--border);overflow-y:auto;z-index:400;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.sbi{padding:1.75rem 1.25rem;display:flex;flex-direction:column;gap:1.25rem}
.sblogo{display:flex;align-items:center;gap:.75rem;padding-bottom:1.25rem;border-bottom:1px solid var(--border)}
.sblm{width:38px;height:38px;background:linear-gradient(135deg,var(--gold),var(--blue));border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:1.3rem;color:#000;flex-shrink:0}
.sblt{display:flex;flex-direction:column;line-height:1.2}
.sblt span:first-child{font-size:.58rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted)}
.sblt span:last-child{font-family:'Playfair Display',serif;font-size:.9rem;color:var(--gold)}
.sbbadges{display:flex;flex-wrap:wrap;gap:.4rem}
.sbb{display:inline-flex;align-items:center;gap:.3rem;padding:.28rem .6rem;border-radius:4px;font-size:.68rem;text-decoration:none;border:1px solid transparent;transition:all .2s}
.sbb:hover{text-decoration:none}
.sbb-o{background:rgba(166,206,57,.1);border-color:rgba(166,206,57,.3);color:#a6ce39}
.sbb-o:hover{background:rgba(166,206,57,.2);border-color:#a6ce39}
.sbb-d{background:rgba(200,169,110,.1);border-color:rgba(200,169,110,.3);color:var(--gold)}
.sbb-d:hover{background:rgba(200,169,110,.2);border-color:var(--gold)}
.sbb-k{background:rgba(255,94,91,.1);border-color:rgba(255,94,91,.3);color:#ff5e5b}
.sbb-k:hover{background:rgba(255,94,91,.2);border-color:#ff5e5b}
.sbacts{display:flex;flex-direction:column;gap:.4rem}
.sbbtn{display:flex;align-items:center;gap:.5rem;padding:.5rem .8rem;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text2);font-family:'Open Sans',sans-serif;font-size:.75rem;cursor:pointer;transition:all .2s;text-align:left}
.sbbtn:hover{background:var(--border);color:var(--text)}
.sbrt{font-size:.68rem;color:var(--muted);padding:.4rem 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
#toc{flex:1}
.toclist{list-style:none}
.toclink{display:flex;align-items:flex-start;gap:.5rem;padding:.3rem .4rem;border-radius:4px;text-decoration:none;color:var(--text2);font-size:.75rem;line-height:1.4;transition:all .2s}
.toclink:hover{color:var(--text);background:rgba(255,255,255,.04);text-decoration:none}
.toclink.active{color:var(--gold);background:rgba(200,169,110,.08)}
.tocdot{width:2px;min-height:12px;background:transparent;border-radius:1px;flex-shrink:0;margin-top:3px;transition:background .2s}
.toclink.active .tocdot{background:var(--gold)}
.tocsub .toclink{padding-left:1rem;font-size:.7rem;color:var(--muted)}
.tocsub .toclink:hover{color:var(--text2)}
.tocsub .toclink.active{color:var(--blue)}
.tocsub .toclink.active .tocdot{background:var(--blue)}
.toclbl{flex:1}
.tocinfo{font-size:.7rem;color:var(--muted);padding:.75rem .4rem}

/* MAIN */
#main{margin-left:var(--sidebar);min-height:100vh;display:flex;flex-direction:column}

/* SEARCH BAR */
#srchbar{position:sticky;top:0;z-index:100;background:var(--surface);border-bottom:1px solid var(--border);padding:.6rem 1.5rem}
#srchbar.hidden{display:none}
.srchi{display:flex;align-items:center;gap:.6rem;max-width:760px}
#srchq{flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:'Open Sans',sans-serif;font-size:.9rem;padding:.4rem .75rem;outline:none}
#srchq:focus{border-color:var(--gold)}
#srchcnt{font-size:.7rem;color:var(--muted);white-space:nowrap}
.sb2{background:var(--surface2);border:1px solid var(--border);color:var(--text2);border-radius:4px;padding:.3rem .55rem;cursor:pointer;font-size:.8rem;transition:all .2s}
.sb2:hover{background:var(--border);color:var(--text)}
mark.sh{background:rgba(200,169,110,.25);color:var(--gold);border-radius:2px;padding:0 2px}
mark.sh.cur{background:var(--gold);color:#000}

/* CONTENT */
#content{flex:1;padding:3.5rem 4.5rem;max-width:820px}
.ctload{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem;min-height:60vh;color:var(--muted);font-size:.85rem}
.spin{width:32px;height:32px;border:2px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.cterr{padding:2rem;border:1px solid rgba(200,169,110,.3);border-radius:8px;background:rgba(200,169,110,.05)}
.cterr h2{font-family:'Playfair Display',serif;color:var(--gold);margin-bottom:.75rem;font-size:1.3rem}

/* TYPOGRAPHY */
#content h1{font-family:'Playfair Display',serif;font-size:2rem;line-height:1.3;color:var(--text);margin-bottom:.5rem;margin-top:2.5rem;scroll-margin-top:80px}
#content h2{font-family:'Playfair Display',serif;font-size:1.6rem;line-height:1.3;color:var(--text);margin-top:3rem;margin-bottom:1rem;padding-bottom:.6rem;border-bottom:1px solid var(--border);scroll-margin-top:80px}
#content h3{font-family:'Playfair Display',serif;font-size:1.2rem;color:var(--gold);margin-top:2.25rem;margin-bottom:.85rem;scroll-margin-top:80px}
#content h4{font-family:'Open Sans',sans-serif;font-size:1rem;font-weight:600;font-style:italic;color:var(--blue);margin-top:1.75rem;margin-bottom:.7rem;scroll-margin-top:80px}
#content p{font-size:1rem;line-height:1.85;color:var(--text);margin-bottom:1.15rem}
#content strong{color:var(--text);font-weight:600}
#content em{color:var(--text2);font-style:italic}
#content a{color:var(--gold);text-decoration:underline;text-underline-offset:3px;text-decoration-color:rgba(200,169,110,.4)}
#content a:hover{color:#debb7e;text-decoration-color:var(--gold)}
#content ul,#content ol{margin:1rem 0 1.4rem 1.5rem;color:var(--text)}
#content li{margin-bottom:.5rem;line-height:1.8;font-size:1rem}
#content ul li::marker{color:var(--gold)}
#content ol li::marker{color:var(--gold);font-size:.85rem}
#content blockquote{margin:1.75rem 0;padding:1.1rem 1.4rem;border-left:3px solid var(--gold);background:rgba(200,169,110,.05);border-radius:0 6px 6px 0}
#content blockquote p{margin:0;color:var(--text2);font-style:italic;font-size:1.02rem}
#content code{font-family:'Courier New',monospace;font-size:.82rem;background:var(--surface2);border:1px solid var(--border);padding:.1em .4em;border-radius:3px;color:var(--blue)}
#content pre{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:1.2rem 1.4rem;overflow-x:auto;margin:1.4rem 0}
#content pre code{background:none;border:none;padding:0;font-size:.82rem;color:var(--text2)}
#content hr{border:none;border-top:1px solid var(--border);margin:2.5rem 0}
#content table{width:100%;border-collapse:collapse;margin:1.75rem 0;font-size:.88rem}
#content th{background:var(--surface2);color:var(--gold);font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;padding:.7rem 1rem;text-align:left;border-bottom:1px solid var(--border)}
#content td{padding:.6rem 1rem;border-bottom:1px solid var(--border);color:var(--text2);vertical-align:top;line-height:1.6}
#content tr:hover td{background:rgba(255,255,255,.02)}
#content img{max-width:100%;border-radius:8px;border:1px solid var(--border);margin:1.4rem 0}

/* FOOTER */
#footer{background:var(--surface);border-top:1px solid var(--border);padding:2.5rem 4.5rem}
.fti{max-width:820px;display:flex;flex-direction:column;gap:.85rem}
.ftq{font-family:'Playfair Display',serif;font-style:italic;font-size:1.05rem;color:var(--text2);line-height:1.5}
.fta{font-size:.72rem;color:var(--muted)}
.ftl{display:flex;flex-wrap:wrap;gap:.5rem .75rem;align-items:center;font-size:.72rem;margin-top:.25rem}
.ftl a{color:var(--gold);text-decoration:none;transition:color .2s}
.ftl a:hover{color:#debb7e}
.ftl span{color:var(--border)}
.ftc a{color:var(--blue);font-size:.72rem;text-decoration:none}
.ftc a:hover{color:#9ed8f0}
.ftx{font-size:.66rem;color:var(--muted);margin-top:.1rem}

/* BTT */
#btt{position:fixed;bottom:1.75rem;right:1.75rem;width:44px;height:44px;background:var(--surface);border:1px solid var(--border);border-radius:50%;color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transform:translateY(10px);transition:all .3s;z-index:99}
#btt.on{opacity:1;transform:translateY(0)}
#btt:hover{background:var(--surface2);border-color:var(--gold);color:var(--gold)}

/* PRINT */
@media print{
  #sb,#mhdr,#mact,#srchbar,#pb,#btt,#footer,#ov{display:none!important}
  #main{margin-left:0!important}
  #content{padding:1cm!important;max-width:100%!important}
  body{background:#fff!important;color:#000!important;font-size:11pt!important}
  #content h1,#content h2,#content h3,#content h4{color:#000!important}
  #content a{color:#000!important}
  #content blockquote{border-left:2pt solid #888!important;background:none!important}
  #content code,#content pre{background:#f5f5f5!important;color:#333!important;border:1pt solid #ccc!important}
  #content h2{page-break-before:always}
}

/* RESPONSIVE */
@media(max-width:1200px){#content{padding:3rem 3rem}#footer{padding:2rem 3rem}}
@media(max-width:1023px){
  #mhdr{display:flex}
  #mact{display:flex}
  #ov{display:block}
  #sb{transform:translateX(-100%);transition:transform .3s cubic-bezier(.4,0,.2,1);top:0;width:min(var(--sidebar),88vw)}
  #sb.open{transform:translateX(0)}
  #main{margin-left:0;padding-top:calc(var(--hdr) + var(--actions))}
  #content{padding:2rem 1.75rem}
  #footer{padding:2rem 1.75rem}
  #content h1{font-size:1.7rem}
  #content h2{font-size:1.35rem}
  #content h3{font-size:1.1rem}
}
@media(max-width:600px){
  #content{padding:1.5rem 1.1rem}
  #footer{padding:1.75rem 1.1rem}
  #content h1{font-size:1.45rem}
  #content h2{font-size:1.2rem;margin-top:2.25rem}
  #content h3{font-size:1.05rem;margin-top:1.75rem}
  #content p,#content li{font-size:.97rem;line-height:1.85}
  #content table{font-size:.8rem}
  #content th,#content td{padding:.45rem .6rem}
  .ftl{flex-direction:column;align-items:flex-start}
  .ftl span{display:none}
  #btt{bottom:1rem;right:1rem}
}
</style>
</head>
